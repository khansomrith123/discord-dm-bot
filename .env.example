# Discord Bot Token (យកពី Discord Developer Portal)
# Get from: https://discord.com/developers/applications
TOKEN=YOUR_BOT_TOKEN_HERE

# Bot Client ID (Application ID)
CLIENT_ID=YOUR_CLIENT_ID_HERE

# Guild ID (Server ID for testing - optional for development)
GUILD_ID=YOUR_GUILD_ID_HERE

# Role ID for announcements (អ្នកមានតួនាទីប្រកាស)
ANNOUNCEMENT_ROLE_ID=YOUR_ROLE_ID_HERE